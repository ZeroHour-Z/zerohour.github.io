---
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

const meta = {
  description: 'Not found',
  title: '404'
}
---

<PageLayout {meta}>
  <div class='flex flex-col items-center justify-center py-16 sm:py-24 text-center'>
    {/* Floating decorative elements */}
    <div class='relative mb-6'>
      <div class='absolute -top-8 -left-12 w-20 h-20 rounded-full border border-primary/20 animate-orbit'></div>
      <div class='absolute -bottom-4 -right-8 w-10 h-10 rounded-full bg-primary/10 animate-orbit-reverse'></div>
      <div class='absolute top-1/2 -right-16 w-3 h-3 rounded-full bg-primary/30 animate-pulse-dot'></div>

      <h1 class='text-[8rem] sm:text-[12rem] font-bold leading-none select-none
                 bg-gradient-to-br from-primary via-foreground/60 to-muted-foreground
                 bg-clip-text text-transparent animate-float'>
        404
      </h1>
    </div>

    <p class='text-xl sm:text-2xl font-medium text-foreground/80 mb-2'>
      这个页面飘向了平行宇宙
    </p>
    <p class='text-muted-foreground max-w-md'>
      你要找的内容可能已经移动或不存在，试试返回首页重新开始吧
    </p>

    <div class='flex gap-3 mt-8'>
      <Button title='返回首页' href='/' variant='ahead' />
      <Button title='浏览博客' href='/blog' variant='ahead' />
    </div>
  </div>
</PageLayout>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @keyframes orbit {
    0% {
      transform: rotate(0deg) translateX(8px) rotate(0deg);
      opacity: 0.4;
    }
    50% {
      opacity: 0.8;
    }
    100% {
      transform: rotate(360deg) translateX(8px) rotate(-360deg);
      opacity: 0.4;
    }
  }

  @keyframes orbit-reverse {
    0% {
      transform: rotate(0deg) translateX(6px) rotate(0deg);
      opacity: 0.3;
    }
    50% {
      opacity: 0.6;
    }
    100% {
      transform: rotate(-360deg) translateX(6px) rotate(360deg);
      opacity: 0.3;
    }
  }

  @keyframes pulse-dot {
    0%, 100% {
      transform: scale(1);
      opacity: 0.3;
    }
    50% {
      transform: scale(1.8);
      opacity: 0.8;
    }
  }

  .animate-float {
    animation: float 4s ease-in-out infinite;
  }

  .animate-orbit {
    animation: orbit 10s linear infinite;
  }

  .animate-orbit-reverse {
    animation: orbit-reverse 8s linear infinite;
  }

  .animate-pulse-dot {
    animation: pulse-dot 3s ease-in-out infinite;
  }

  @media (prefers-reduced-motion) {
    .animate-float,
    .animate-orbit,
    .animate-orbit-reverse,
    .animate-pulse-dot {
      animation: none;
    }
  }
</style>
