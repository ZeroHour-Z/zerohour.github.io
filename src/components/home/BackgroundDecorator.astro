---
interface Props {
  type?: 'gradient' | 'solid' | 'image' | 'animated' | 'none'
  color1?: string
  color2?: string
  imageUrl?: string
  opacity?: number
}

const {
  type = 'gradient',
  color1 = '#667eea',
  color2 = '#764ba2',
  imageUrl = '/path/to/background.jpg',
  opacity = 0.1
} = Astro.props
---

{type === 'gradient' && (
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0" style={`background: linear-gradient(135deg, ${color1}20, ${color2}20);`}></div>
    <div class="absolute top-0 -left-4 w-72 h-72 bg-purple-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob"></div>
    <div class="absolute top-0 -right-4 w-72 h-72 bg-yellow-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-8 left-20 w-72 h-72 bg-pink-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-4000"></div>
  </div>
)}

{type === 'solid' && (
  <div class="fixed inset-0 -z-10" style={`background-color: ${color1}; opacity: ${opacity};`}></div>
)}

{type === 'image' && (
  <div
    class="fixed inset-0 -z-10 bg-cover bg-center bg-no-repeat"
    style={`background-image: url(${imageUrl}); opacity: ${opacity};`}
  ></div>
)}

{type === 'animated' && (
  <div class="aurora-wrap fixed inset-0 overflow-hidden" style="z-index: 0; pointer-events: none;">
    <div class="aurora-base"></div>
    <div class="aurora-glow glow-left"></div>
    <div class="aurora-glow glow-center"></div>
    <div class="aurora-glow glow-right"></div>
    <div class="aurora-blob blob-1"></div>
    <div class="aurora-blob blob-2"></div>
    <div class="aurora-blob blob-3"></div>
    <div class="aurora-vignette"></div>
    <div class="aurora-fade"></div>
  </div>
)}

<style>
  /* gradient type */
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob { animation: blob 7s infinite; }
  .animation-delay-2000 { animation-delay: 2s; }
  .animation-delay-4000 { animation-delay: 4s; }

  /* Elegant aurora background */
  .aurora-base {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      #102b46 0%,
      #173755 26%,
      #182f45 48%,
      hsl(210 33% 99%) 78%
    );
  }
  :global(.dark) .aurora-base {
    background: linear-gradient(
      180deg,
      #0a1830 0%,
      #101f37 26%,
      #0f1a2a 48%,
      hsl(240 20.54% 5.2%) 78%
    );
  }

  .aurora-glow,
  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  .aurora-glow {
    filter: blur(90px);
    opacity: 0.42;
  }
  .glow-left {
    width: 54vw;
    height: 54vw;
    top: -24%;
    left: -14%;
    background: radial-gradient(circle, rgba(70, 106, 255, 0.34), transparent 72%);
  }
  .glow-center {
    width: 42vw;
    height: 42vw;
    top: -18%;
    left: 32%;
    background: radial-gradient(circle, rgba(79, 160, 255, 0.24), transparent 72%);
  }
  .glow-right {
    width: 46vw;
    height: 46vw;
    top: -20%;
    right: -12%;
    background: radial-gradient(circle, rgba(255, 168, 96, 0.2), transparent 72%);
  }

  /* light blobs */
  .blob-1 {
    width: 58vw;
    height: 58vw;
    top: -26%;
    left: -10%;
    filter: blur(120px);
    background: radial-gradient(circle, rgba(80, 110, 255, 0.25), transparent 72%);
    animation: drift-1 44s ease-in-out infinite;
  }
  .blob-2 {
    width: 48vw;
    height: 48vw;
    top: -22%;
    right: -8%;
    filter: blur(108px);
    background: radial-gradient(circle, rgba(255, 160, 90, 0.2), transparent 72%);
    animation: drift-2 50s ease-in-out infinite;
  }
  .blob-3 {
    width: 44vw;
    height: 44vw;
    top: -8%;
    left: 28%;
    filter: blur(124px);
    background: radial-gradient(circle, rgba(120, 95, 255, 0.2), transparent 72%);
    animation: drift-3 46s ease-in-out infinite;
  }

  /* dark tune */
  :global(.dark) .aurora-glow {
    opacity: 0.5;
  }
  :global(.dark) .glow-left {
    background: radial-gradient(circle, rgba(45, 82, 210, 0.42), transparent 72%);
  }
  :global(.dark) .glow-center {
    background: radial-gradient(circle, rgba(67, 118, 220, 0.3), transparent 72%);
  }
  :global(.dark) .glow-right {
    background: radial-gradient(circle, rgba(175, 110, 70, 0.24), transparent 72%);
  }
  :global(.dark) .blob-1 {
    background: radial-gradient(circle, rgba(67, 56, 202, 0.34), transparent 72%);
  }
  :global(.dark) .blob-2 {
    background: radial-gradient(circle, rgba(176, 107, 60, 0.28), transparent 72%);
  }
  :global(.dark) .blob-3 {
    background: radial-gradient(circle, rgba(100, 68, 210, 0.3), transparent 72%);
  }

  /* soft movement */
  @keyframes drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(4vw, 4vh) scale(1.04); }
    66% { transform: translate(-3vw, 7vh) scale(0.97); }
  }
  @keyframes drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40% { transform: translate(-6vw, 5vh) scale(1.03); }
    75% { transform: translate(2vw, -2vh) scale(0.97); }
  }
  @keyframes drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    30% { transform: translate(5vw, -4vh) scale(1.04); }
    70% { transform: translate(-2vw, 3vh) scale(0.96); }
  }

  .aurora-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 70% at 50% -10%, transparent 35%, rgba(0, 0, 0, 0.12) 100%);
  }
  :global(.dark) .aurora-vignette {
    background:
      radial-gradient(120% 70% at 50% -10%, transparent 30%, rgba(0, 0, 0, 0.24) 100%);
  }

  /* transparent top -> opaque lower section */
  .aurora-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 34%,
      hsl(210 33% 99% / 0.35) 48%,
      hsl(210 33% 99% / 0.82) 64%,
      hsl(210 33% 99% / 1) 80%
    );
    pointer-events: none;
  }
  :global(.dark) .aurora-fade {
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 34%,
      hsl(240 20.54% 5.2% / 0.35) 48%,
      hsl(240 20.54% 5.2% / 0.82) 64%,
      hsl(240 20.54% 5.2% / 1) 80%
    );
  }

  @media (max-width: 768px) {
    .aurora-glow,
    .aurora-blob {
      filter: blur(84px);
    }
    .glow-left,
    .blob-1 { width: 90vw; height: 90vw; }
    .glow-right,
    .blob-2 { width: 76vw; height: 76vw; }
    .glow-center,
    .blob-3 { width: 68vw; height: 68vw; }
    .aurora-fade {
      background: linear-gradient(
        to bottom,
        transparent 0%,
        transparent 28%,
        hsl(210 33% 99% / 0.46) 44%,
        hsl(210 33% 99% / 0.86) 60%,
        hsl(210 33% 99% / 1) 76%
      );
    }
    :global(.dark) .aurora-fade {
      background: linear-gradient(
        to bottom,
        transparent 0%,
        transparent 28%,
        hsl(240 20.54% 5.2% / 0.46) 44%,
        hsl(240 20.54% 5.2% / 0.86) 60%,
        hsl(240 20.54% 5.2% / 1) 76%
      );
    }
  }

  @media (prefers-reduced-motion) {
    .aurora-blob { animation: none !important; }
  }
</style>
